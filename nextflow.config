// ─────────────────────────────────────────────────────────────────────────────
//  nextflow.config
//  Profiles: local (default), docker, conda, slurm
// ─────────────────────────────────────────────────────────────────────────────

manifest {
    name        = 'SeqMatcher'
    description = 'Sequence motif search pipeline — JASPAR-driven mismatch/PWM scanning, BED and BigWig outputs'
    version     = '3.0.0'
    author      = 'Your Lab'
    nextflowVersion = '>=23.04'
}

// ── Default parameters (can be overridden on the CLI with --param value) ──────
params {
    input_dir      = "input"
    // Fallback consensus string used when --jaspar is not provided.
    // When --jaspar IS provided, the consensus is derived exclusively from
    // the JASPAR counts matrix via consensus_from_counts() in the Python
    // script, making --query a cross-check only (a warning is printed if
    // they differ). Corrected from previous "AGGGAATTTCCC" typo.
    query          = "AGGGGATTTCCC"
    mode           = "mismatch"   // exact | mismatch | pwm
    mismatches     = 2            // max Hamming mismatches (mismatch/pwm modes)
    upstream       = 150
    downstream     = 150
    // JASPAR-format counts file — the single source of truth for the consensus
    // in ALL three modes:
    //   mismatch : consensus_from_counts() drives Hamming comparisons (recommended)
    //   exact    : consensus_from_counts() drives the IUPAC regex
    //   pwm      : required; also builds log-odds matrix and annotates mismatches
    // Using the same .jaspar file in both this pipeline and the genome-wide
    // script guarantees every peak hit is a strict subset of genome-wide hits.
    jaspar         = null
    pvalue         = 1e-4         // p-value threshold for PWM hit calling
    pseudocount    = 0.1          // pseudocount added to each PWM cell
    bg_gc          = 0.5          // background GC fraction for null distribution
    fwd_only       = false        // true → scan forward strand only
    outdir         = "results"
    genome         = "input/genome/genome.fa"
    use_docker     = true
    tracedir       = "${params.outdir}/pipeline_info"
}

// ── Process-level defaults ────────────────────────────────────────────────────
process {
    cpus   = 2
    memory = '4 GB'
    time   = '2h'

    withName: FETCH_SEQUENCES {
        cpus   = 2
        memory = '4 GB'
        time   = '1h'
    }

    withName: MATCH_AND_MOTIFS {
        cpus   = 4
        memory = '8 GB'
        time   = '4h'
    }

    withName: INDEX_BIGWIG {
        cpus   = 1
        memory = '2 GB'
        time   = '30m'
    }
}

// ── Execution profiles ────────────────────────────────────────────────────────
profiles {

    // ── Local execution with Docker (default) ─────────────────────────────────
    // fixOwnership: Nextflow writes output files as root inside the container;
    //               this flag chowns them back to the host user on exit.
    // platform:     Force the container to run with the host's native arch.
    //               Eliminates the linux/amd64 vs arm64 emulation warning on
    //               Apple Silicon and avoids QEMU-related crashes.
    docker {
        docker.enabled     = true
        docker.fixOwnership = true
        docker.platform    = 'linux/arm64'   // ← change to linux/amd64 on Intel/AMD hosts
        process.executor   = 'local'
    }

    // ── Same as docker but for Intel/AMD hosts (x86_64) ───────────────────────
    docker_amd64 {
        docker.enabled      = true
        docker.fixOwnership = true
        docker.platform     = 'linux/amd64'
        process.executor    = 'local'
    }

    // ── Local execution with Conda ────────────────────────────────────────────
    conda {
        conda.enabled    = true
        conda.useMamba   = false          // set true if mamba is on PATH
        process.executor = 'local'

        process {
            withName: FETCH_SEQUENCES  { conda = "${projectDir}/envs/seqmatcher.yml" }
            withName: MATCH_AND_MOTIFS { conda = "${projectDir}/envs/seqmatcher.yml" }
            withName: INDEX_BIGWIG     { conda = "${projectDir}/envs/ucsc.yml" }
        }
    }

    // ── SLURM HPC execution with Docker ──────────────────────────────────────
    slurm {
        docker.enabled   = true
        process.executor = 'slurm'
        process.queue    = 'standard'

        process {
            withName: FETCH_SEQUENCES {
                cpus   = 4
                memory = '8 GB'
                time   = '2h'
            }
            withName: MATCH_AND_MOTIFS {
                cpus   = 8
                memory = '16 GB'
                time   = '8h'
            }
            withName: INDEX_BIGWIG {
                cpus   = 2
                memory = '4 GB'
                time   = '1h'
            }
        }
    }

    // ── SLURM + Conda (no Docker on cluster) ─────────────────────────────────
    slurm_conda {
        conda.enabled    = true
        process.executor = 'slurm'
        process.queue    = 'standard'

        process {
            withName: FETCH_SEQUENCES  { conda = "${projectDir}/envs/seqmatcher.yml" }
            withName: MATCH_AND_MOTIFS { conda = "${projectDir}/envs/seqmatcher.yml" }
            withName: INDEX_BIGWIG     { conda = "${projectDir}/envs/ucsc.yml" }

            withName: MATCH_AND_MOTIFS {
                cpus   = 8
                memory = '16 GB'
                time   = '8h'
            }
        }
    }
}

// ── Execution reporting ───────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.tracedir}/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.tracedir}/report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.tracedir}/trace.txt"
    overwrite = true
    fields  = 'task_id,name,status,exit,realtime,%cpu,rss,peak_rss'
}

dag {
    enabled   = true
    file      = "${params.tracedir}/dag.svg"
    overwrite = true
}
